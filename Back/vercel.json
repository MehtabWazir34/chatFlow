{
    "version": 2, 
    "builds":[
        {
            "src": "MyApp.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles":[
                    "uploads/**"
                ]
            }
        }

    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "MyApp.js"
        }
    ]
}